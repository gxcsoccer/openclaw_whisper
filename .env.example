# whisper.cpp paths
WHISPER_BIN=/path/to/whisper.cpp/main
WHISPER_MODEL=/path/to/whisper.cpp/models/ggml-large-v3.bin

# Whisper options
WHISPER_LANGUAGE=zh
WHISPER_THREADS=8

# STT server
STT_HOST=0.0.0.0
STT_PORT=8765

# Feishu credentials
FEISHU_APP_ID=your_app_id
FEISHU_APP_SECRET=your_app_secret
